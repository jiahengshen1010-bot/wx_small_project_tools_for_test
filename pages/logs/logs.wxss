.logs-page {
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx 0;
}

.title {
  color: #111827;
  font-size: 40rpx;
  font-weight: 700;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.log-item,
.empty {
  padding: 28rpx;
  color: #374151;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}
